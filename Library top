        SliceCenter = Rect.new(100, 100, 100, 100),
        SliceScale = 0.02,
        Parent = colorBoxOutline,
    })

    local inContact = false
    option.main.InputBegan:Connect(function(input)
        if input.UserInputType == ui or input.UserInputType == touch then
            if not option.mainHolder then createColorPickerWindow(option) end
            if library.activePopup then library.activePopup:Close() end
            local pos = option.main.AbsolutePosition
            option.mainHolder.Position = UDim2.new(0, pos.X - 5, 0, pos.Y - 10)
            option.open = true
            option.mainHolder.Visible = true
            library.activePopup = option
            tweenService:Create(option.mainHolder, TweenInfo.new(0.3, Enum.EasingStyle.Quint), { ImageTransparency = 0, Position = UDim2.new(0, pos.X - 5, 0, pos.Y - 4) }):Play()
            tweenService:Create(option.mainHolder, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, 0, false, 0.1), { Position = UDim2.new(0, pos.X - 5, 0, pos.Y + 1) }):Play()
            tweenService:Create(option.satval, TweenInfo.new(0.3), { BackgroundTransparency = 0 }):Play()
            for _, obj in pairs(option.mainHolder:GetDescendants()) do
                if obj:IsA("TextLabel") then
                    tweenService:Create(obj, TweenInfo.new(0.3), { TextTransparency = 0 }):Play()
                elseif obj:IsA("ImageLabel") then
                    tweenService:Create(obj, TweenInfo.new(0.3), { ImageTransparency = 0 }):Play()
                elseif obj:IsA("Frame") then
                    tweenService:Create(obj, TweenInfo.new(0.3), { BackgroundTransparency = 0 }):Play()
                end
            end
        elseif input.UserInputType == Enum.UserInputType.MouseMovement then
            inContact = true
            if not option.open then
                tweenService:Create(colorBoxOutline, TweenInfo.new(0.1), { ImageColor3 = Color3.fromRGB(140, 140, 140) }):Play()
            end
        end
    end)

    option.main.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            inContact = false
            if not option.open then
                tweenService:Create(colorBoxOutline, TweenInfo.new(0.1), { ImageColor3 = Color3.fromRGB(100, 100, 100) }):Play()
            end
        end
    end)

    function option:SetColor(newColor)
        if self.mainHolder then self:updateVisuals(newColor) end
        self.visualize.ImageColor3 = newColor
        library.flags[self.flag] = newColor
        self.color = newColor
        self.callback(newColor)
    end

    function option:Close()
        library.activePopup = nil
        self.open = false
        local pos = self.main.AbsolutePosition
        tweenService:Create(self.mainHolder, TweenInfo.new(0.3), { ImageTransparency = 1, Position = UDim2.new(0, pos.X - 5, 0, pos.Y - 10) }):Play()
        tweenService:Create(self.satval, TweenInfo.new(0.3), { BackgroundTransparency = 1 }):Play()
        for _, obj in pairs(self.mainHolder:GetDescendants()) do
            if obj:IsA("TextLabel") then
                tweenService:Create(obj, TweenInfo.new(0.3), { TextTransparency = 1 }):Play()
            elseif obj:IsA("ImageLabel") then
                tweenService:Create(obj, TweenInfo.new(0.3), { ImageTransparency = 1 }):Play()
            elseif obj:IsA("Frame") then
                tweenService:Create(obj, TweenInfo.new(0.3), { BackgroundTransparency = 1 }):Play()
            end
        end
        task.delay(0.3, function()
            if not self.open then self.mainHolder.Visible = false end
        end)
    end
end

-- Carrega as opções de uma janela/aba
local function loadOptions(holder)
    for _, opt in ipairs(holder.options) do
        if opt.type == "label" then
            createLabel(opt, holder)
        elseif opt.type == "toggle" then
            createToggle(opt, holder)
        elseif opt.type == "button" then
            createButton(opt, holder)
        elseif opt.type == "bind" then
            createBind(opt, holder)
        elseif opt.type == "slider" then
            createSlider(opt, holder)
        elseif opt.type == "list" then
            createList(opt, holder)
        elseif opt.type == "box" then
            createBox(opt, holder)
        elseif opt.type == "color" then
            createColor(opt, holder)
        elseif opt.type == "folder" then
            opt:init()
        end
    end
end

-- Métodos para adicionar componentes a um holder (janela ou pasta)
local function getFunctions(holder)
    function holder:AddLabel(opt)
        opt = opt or {}
        opt.text = tostring(opt.text)
        opt.type = "label"
        opt.position = #self.options
        table.insert(self.options, opt)
        return opt
    end

    function holder:AddToggle(opt)
        opt = opt or {}
        opt.text = tostring(opt.text)
        opt.state = opt.state == true
        opt.callback = opt.callback or function() end
        opt.type = "toggle"
        opt.position = #self.options
        opt.flag = opt.flag or opt.text
        library.flags[opt.flag] = opt.state
        table.insert(self.options, opt)
        return opt
    end

    function holder:AddButton(opt)
        opt = opt or {}
        opt.text = tostring(opt.text)
        opt.callback = opt.callback or function() end
        opt.type = "button"
        opt.position = #self.options
        opt.flag = opt.flag or opt.text
        table.insert(self.options, opt)
        return opt
    end

    function holder:AddBind(opt)
        opt = opt or {}
        opt.text = tostring(opt.text)
        opt.key = (opt.key and opt.key.Name) or opt.key or "F"
        opt.hold = opt.hold == true
        opt.callback = opt.callback or function() end
        opt.type = "bind"
        opt.position = #self.options
        opt.flag = opt.flag or opt.text
        library.flags[opt.flag] = opt.key
        table.insert(self.options, opt)
        return opt
    end

    function holder:AddSlider(opt)
        opt = opt or {}
        opt.text = tostring(opt.text)
        opt.min = opt.min or 0
        opt.max = opt.max or 100
        opt.value = math.clamp(opt.value or opt.min, opt.min, opt.max)
        opt.callback = opt.callback or function() end
        opt.float = opt.float or 1
        opt.type = "slider"
        opt.position = #self.options
        opt.flag = opt.flag or opt.text
        library.flags[opt.flag] = opt.value
        table.insert(self.options, opt)
        return opt
    end

    function holder:AddList(opt)
        opt = opt or {}
        opt.text = tostring(opt.text)
        opt.values = opt.values or {}
        opt.value = tostring(opt.value or opt.values[1] or "")
        opt.callback = opt.callback or function() end
        opt.open = false
        opt.type = "list"
        opt.position = #self.options
        opt.flag = opt.flag or opt.text
        library.flags[opt.flag] = opt.value
        table.insert(self.options, opt)
        return opt
    end

    function holder:AddBox(opt)
        opt = opt or {}
        opt.text = tostring(opt.text)
        opt.value = tostring(opt.value or "")
        opt.callback = opt.callback or function() end
        opt.type = "box"
        opt.position = #self.options
        opt.flag = opt.flag or opt.text
        library.flags[opt.flag] = opt.value
        table.insert(self.options, opt)
        return opt
    end

    function holder:AddColor(opt)
        opt = opt or {}
        opt.text = tostring(opt.text)
        if type(opt.color) == "table" then
            opt.color = Color3.new(opt.color[1], opt.color[2], opt.color[3])
        elseif not opt.color then
            opt.color = Color3.new(1, 1, 1)
        end
        opt.callback = opt.callback or function() end
        opt.open = false
        opt.type = "color"
        opt.position = #self.options
        opt.flag = opt.flag or opt.text
        library.flags[opt.flag] = opt.color
        table.insert(self.options, opt)
        return opt
    end

    function holder:AddFolder(title)
        local folder = {
            title = tostring(title),
            options = {},
            open = false,
            type = "folder",
            position = #self.options,
        }
        table.insert(self.options, folder)
        getFunctions(folder)
        function folder:init()
            createOptionHolder(self.title, holder.content, self, true)
            loadOptions(self)
        end
        return folder
    end
end

-- Cria uma nova janela
function library:CreateWindow(title)
    local window = {
        title = tostring(title),
        options = {},
        open = true,
        canInit = true,
        init = false,
        position = #self.windows,
    }
    getFunctions(window)
    table.insert(self.windows, window)
    return window
end

-- Inicializa a GUI (deve ser chamada após criar as janelas)
function library:Init()
    self.base = self:Create("ScreenGui")
    if syn and syn.protect_gui then
        syn.protect_gui(self.base)
    elseif get_hidden_gui then
        get_hidden_gui(self.base)
    elseif gethui then
        gethui(self.base)
    else
        game:GetService("Players").LocalPlayer:Kick("Error: protect_gui function not found")
        return
    end
    self.base.Parent = game:GetService("CoreGui")
    self.base.ResetOnSpawn = true
    self.base.Name = "ToraScript"

    for _, win in ipairs(self.windows) do
        if win.canInit and not win.init then
            win.init = true
            createOptionHolder(win.title, self.base, win)
            loadOptions(win)
        end
    end
    return self.base
end

-- Minimizar/Restaurar todas as janelas
function library:ToggleMinimize()
    self.open = not self.open
    if self.activePopup then self.activePopup:Close() end
    for _, win in ipairs(self.windows) do
        if win.main then
            win.main.Visible = self.open
        end
    end
end

