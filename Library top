--[[
    ToraScript UI Library - Versão Aprimorada
    Mantém o estilo original, mas com código otimizado, animações suaves,
    suporte a minimizar/restaurar, e componentes mais responsivos.
]]

local library = {
    flags = {},
    windows = {},
    open = true,
    activePopup = nil,
    base = nil,
    minimized = false, -- estado global de minimizar (opcional)
}

-- Services
local runService = game:GetService("RunService")
local tweenService = game:GetService("TweenService")
local textService = game:GetService("TextService")
local inputService = game:GetService("UserInputService")
local players = game:GetService("Players")
local ui = Enum.UserInputType.MouseButton1
local touch = Enum.UserInputType.Touch

-- Locals
local dragging = false
local dragInput = nil
local dragStart = nil
local startPos = nil
local dragObject = nil

-- Constantes (teclas bloqueadas/permite para binds)
local blacklistedKeys = {
    [Enum.KeyCode.Unknown] = true,
    [Enum.KeyCode.W] = true, [Enum.KeyCode.A] = true, [Enum.KeyCode.S] = true, [Enum.KeyCode.D] = true,
    [Enum.KeyCode.Q] = true, [Enum.KeyCode.E] = true, [Enum.KeyCode.R] = true, [Enum.KeyCode.F] = true,
    [Enum.KeyCode.C] = true, [Enum.KeyCode.V] = true, [Enum.KeyCode.B] = true, [Enum.KeyCode.G] = true,
    [Enum.KeyCode.Z] = true, [Enum.KeyCode.X] = true, [Enum.KeyCode.LeftShift] = true, [Enum.KeyCode.RightShift] = true,
    [Enum.KeyCode.LeftControl] = true, [Enum.KeyCode.RightControl] = true, [Enum.KeyCode.LeftAlt] = true,
    [Enum.KeyCode.RightAlt] = true, [Enum.KeyCode.Space] = true, [Enum.KeyCode.Tab] = true,
    [Enum.KeyCode.CapsLock] = true, [Enum.KeyCode.Escape] = true,
}
local whitelistedMouseinputs = {
    Enum.UserInputType.MouseButton1, Enum.UserInputType.MouseButton2, Enum.UserInputType.MouseButton3,
    Enum.UserInputType.MouseWheel,
}

-- Funções auxiliares
local function round(num, bracket)
    bracket = bracket or 1
    local a = math.floor(num / bracket + (math.sign(num) * 0.5)) * bracket
    if a < 0 then a = a + bracket end
    return a
end

local function keyCheck(x, list)
    for _, v in pairs(list) do
        if v == x then return true end
    end
    return false
end

-- Atualização de arrasto
local function update(input)
    if not dragObject then return end
    local delta = input.Position - dragStart
    local yPos = startPos.Y.Offset + delta.Y
    -- Limitar para não sair da tela
    local maxY = dragObject.Parent.AbsoluteSize.Y - dragObject.AbsoluteSize.Y - 36
    yPos = math.clamp(yPos, -36, maxY)
    dragObject:TweenPosition(UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, yPos), "Out", "Quint", 0.1, true)
end

-- Rainbow effect (melhorado com task.spawn)
