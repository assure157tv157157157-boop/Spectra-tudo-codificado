--------------------------------------------------
--// FUNÇÃO PARA CARREGAR E POSICIONAR MAPA (BACKROOMS)
--------------------------------------------------
local function LoadBackroomsMap()
    local mapID = 10581711055
    local success, model = pcall(function()
        return game:GetObjects("rbxassetid://" .. mapID)[1]
    end)

    if not success or not model then
        warn("Falha ao carregar o mapa das backrooms. Verifique o ID.")
        return false
    end

    -- Posicionar o mapa no local desejado (0, 10000, 0)
    local targetPos = Vector3.new(0, 10000, 0)
    model.Parent = Workspace

    -- Se o modelo tiver PrimaryPart, use SetPrimaryPartCFrame
    local primary = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
    if primary then
        -- Calcula o deslocamento necessário para levar o primary part para targetPos
        local offset = targetPos - primary.Position
        -- Move todas as partes do modelo
        for _, v in ipairs(model:GetDescendants()) do
            if v:IsA("BasePart") then
                v.CFrame = v.CFrame + offset
            end
        end
    else
        warn("Modelo não contém partes base, não foi possível posicionar.")
    end

    return true
end

