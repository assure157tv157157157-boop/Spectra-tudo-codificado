--------------------------------------------------
local Actions = {
    [";kill"] = function() Humanoid().Health = 0 end,
    [";fling"] = function() HRP().Velocity = Vector3.new(6000, 300, 6000) end,
    [";flingop"] = function() HRP().Velocity = Vector3.new(0, 150000, 0) end,

    [";jail"] = function()
        if JailModel then return end

        JailModel = Instance.new("Model", Workspace)
        JailModel.Name = "SpectraJail"

        local base = HRP().CFrame
        local basePosition = base.Position

        local color1 = Color3.fromRGB(255, 50, 50)
        local color2 = Color3.fromRGB(255, 100, 0)
        local transparency = 0.3

        local function createWall(size, position, colorIndex)
            local wall = Instance.new("Part")
            wall.Anchored = true
            wall.CanCollide = true
            wall.Size = size
            wall.Material = Enum.Material.Neon
            wall.Transparency = transparency
            wall.Color = colorIndex == 1 and color1 or color2
            wall.Position = position
            wall.Parent = JailModel

            local surfaceGui = Instance.new("SurfaceGui", wall)
            surfaceGui.Face = Enum.NormalId.Front
            surfaceGui.AlwaysOnTop = true

            local frame = Instance.new("Frame", surfaceGui)
            frame.Size = UDim2.new(1, 0, 1, 0)
            frame.BackgroundTransparency = 1

            local stroke = Instance.new("UIStroke", frame)
            stroke.Color = Color3.fromRGB(255, 150, 50)
            stroke.Thickness = 3

            return wall
        end

        local jailSize = 12

        createWall(Vector3.new(jailSize, 8, 0.5), basePosition + Vector3.new(0, 0, jailSize/2), 1)
        createWall(Vector3.new(jailSize, 8, 0.5), basePosition + Vector3.new(0, 0, -jailSize/2), 2)
        createWall(Vector3.new(0.5, 8, jailSize), basePosition + Vector3.new(jailSize/2, 0, 0), 1)
        createWall(Vector3.new(0.5, 8, jailSize), basePosition + Vector3.new(-jailSize/2, 0, 0), 2)

        local ceiling = Instance.new("Part")
        ceiling.Anchored = true
        ceiling.CanCollide = true
        ceiling.Size = Vector3.new(jailSize + 0.5, 0.5, jailSize + 0.5)
        ceiling.Material = Enum.Material.Neon
        ceiling.Transparency = transparency
        ceiling.Color = color2
        ceiling.Position = basePosition + Vector3.new(0, 4, 0)
        ceiling.Parent = JailModel

        local floor = Instance.new("Part")
        floor.Anchored = true
        floor.CanCollide = true
        floor.Size = Vector3.new(jailSize + 0.5, 0.5, jailSize + 0.5)
        floor.Material = Enum.Material.Neon
        floor.Transparency = transparency
        floor.Color = Color3.fromRGB(200, 0, 0)
        floor.Position = basePosition + Vector3.new(0, -4, 0)
        floor.Parent = JailModel

        local light = Instance.new("PointLight", JailModel)
        light.Color = Color3.fromRGB(255, 100, 50)
        light.Range = 20
        light.Brightness = 1.5
        light.Shadows = true
        light.Position = basePosition

        local function addParticles(part)
            local particleEmitter = Instance.new("ParticleEmitter", part)
            particleEmitter.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, color1),
                ColorSequenceKeypoint.new(1, color2)
            }
            particleEmitter.Size = NumberSequence.new(0.1)
            particleEmitter.Transparency = NumberSequence.new(0.7)
            particleEmitter.Lifetime = NumberRange.new(1, 2)
            particleEmitter.Rate = 5
            particleEmitter.Speed = NumberRange.new(0.5)
        end

        for _, wall in ipairs(JailModel:GetChildren()) do
            if wall:IsA("Part") and wall.Size.Y > 5 then
                addParticles(wall)
            end
        end
    end,

    [";kick"] = function()
        LocalPlayer:Kick("Você foi expulso por um moderador")
    end,

    [";unjail"] = function()
        if JailModel and JailModel.Parent then
            JailModel:Destroy()
            JailModel = nil
        end
    end,

    [";sit"] = function()
        local hum = Humanoid()
        if not hum then return end
        hum.Sit = true
    end,

    [";poison"] = function()
        local hum = Humanoid()
        if not hum then return end

        task.spawn(function()
            for i = 1, 20 do
                if hum.Health <= 0 then break end
                hum.Health = hum.Health - 3
                task.wait(0.5)
            end
        end)
    end,

    [";killplus"] = function()
        local hrp = HRP()
        local hum = Humanoid()
        if not hrp or not hum then return end

        for i = 1, 45 do
            local p = Instance.new("Part")
            p.Size = Vector3.new(0.6, 0.6, 0.6)
            p.Material = Enum.Material.Neon
            p.Color = Color3.fromHSV(math.random(), 1, 1)
            p.CFrame = hrp.CFrame
            p.Anchored = false
            p.CanCollide = true
            p.AssemblyLinearVelocity = Vector3.new(
                math.random(-35, 35),
                math.random(20, 45),
                math.random(-35, 35)
            )
            p.Parent = Workspace

            game:GetService("Debris"):AddItem(p, 2.5)
        end

        hum.Health = 0
    end,

    [";unfrozen"] = function()
        HRP().Anchored = false
        Humanoid().WalkSpeed = 16
        Humanoid().JumpPower = 50
    end,

    [";bomb"] = function()
        local e = Instance.new("Explosion")
        e.Position = HRP().Position
        e.BlastRadius = 20
        e.Parent = Workspace
        Humanoid().Health = 0
    end,

    [";float"] = function()
        StartFloat()
    end,

    [";backrooms"] = function()
        local root = HRP()
        if not root then 
            warn("Sem HumanoidRootPart para teleportar")
            return 
        end

        -- Carrega o mapa
        local loaded = LoadBackroomsMap()
        if loaded then
            print("Mapa das backrooms carregado com sucesso!")
        else
            warn("Falha ao carregar o mapa, mas continuando com o teleporte...")
        end

        -- Teleporta o jogador para as coordenadas das backrooms
        root.CFrame = CFrame.new(59, 9996, 19)
        print("Teleportado para as backrooms!")
    end
}

